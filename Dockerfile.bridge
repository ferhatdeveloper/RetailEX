# pg_bridge (Hono) — web ortamında SQL proxy (:3001)
# Node 22: package.json engines (@capacitor/cli) ile uyum; Dockerfile.frontend ile aynı major
FROM node:22-alpine
WORKDIR /app
COPY package.json package-lock.json* ./
# antd 6 + @ant-design/pro-components — Dockerfile.frontend ile aynı (VPS bridge imaji)
RUN npm ci --legacy-peer-deps
COPY . .
ENV NODE_ENV=production
EXPOSE 3001
CMD ["npx", "tsx", "src/services/pg_bridge.ts"]
