# RetailEX-Logo-Connector Configuration

# PostgreSQL (RetailEX Central DB)
DATABASE_URL=postgres://postgres:postgres@localhost/exretail

# MS SQL (Logo ERP DB)
# Format: Server=tcp:localhost,1433;Database=LOGO_DB;User ID=sa;Password=your_password;
LOGO_DATABASE_URL=Server=tcp:localhost,1433;Database=LOGO_DB;User ID=sa;Password=your_password;TRUST_SERVER_CERTIFICATE=true;

# Logistics
LOG_LEVEL=debug
POLL_INTERVAL_SECONDS=30
