{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../build",
    "devUrl": "http://localhost:6173"
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "",
    "targets": [
      "nsis",
      "dmg",
      "app",
      "deb",
      "appimage"
    ],
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": "C94EB006F97617F5480CD4DA6F719A8EDCBCA37E",
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "allowDowngrades": true,
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": "branding/header.bmp",
        "sidebarImage": "branding/sidebar.bmp",
        "template": "./installer.nsi"
      }
    },
    "longDescription": "",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "resources": [
      "../database/init/**/*",
      "../database/migrations/**/*",
      "../database/sys/**/*"
    ],
    "shortDescription": "",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "createUpdaterArtifacts": false
  },
  "productName": "retailex",
  "mainBinaryName": "retailex",
  "version": "0.1.46",
  "identifier": "com.retailex.app",
  "plugins": {},
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "maximized": true,
        "decorations": true,
        "resizable": true,
        "title": "RetailEX",
        "width": 1024,
        "height": 768,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}