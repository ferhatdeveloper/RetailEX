# Kod imzalama — npm run tauri:build oncesi scripts/tauri-windows-signing-prep.mjs otomatik okur.
# Kopyala: copy .env.signing.example .env.signing  (asla commit etme)

# --- Secenek A: DigiCert ONE / KeyLocker (smctl + cert store) ---
# DigiCert ONE portal API anahtarı
SM_API_KEY=your_api_key_here

# Sertifika parmak izi (DigiCert ONE portaldaki fingerprint)
SM_CERT_FINGERPRINT=your_cert_fingerprint_here

# Client authentication sertifikası (.p12 dosyası)
SM_CLIENT_CERT_FILE=C:\certs\digicert_client.p12

# Client sertifika şifresi
SM_CLIENT_CERT_PASSWORD=your_p12_password_here

# DigiCert ONE sunucu adresi (değiştirme)
SM_HOST=https://clientauth.one.digicert.com

# --- Secenek B: Dogrudan thumbprint (certmgr.msc → Kişisel → Thumbprint) ---
# WINDOWS_CODESIGN_THUMBPRINT=A1B2C3D4E5F6...

# --- Secenek C: Yerel .pfx (build sirasinda CurrentUser\My'ye import) ---
# WINDOWS_CODESIGN_PFX=C:\certs\codesign.pfx
# WINDOWS_CODESIGN_PFX_PASSWORD=secret

# Imzasiz build icin: WINDOWS_CODESIGN_DISABLE=1
